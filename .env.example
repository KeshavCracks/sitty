# ──────────────────────────────────────────────────────────────
# Forge — AI Software Engineer · Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values you need.
# All variables are optional — Forge runs in demo mode without any
# of them set. Add keys to unlock the corresponding features.

# ── Database ──────────────────────────────────────────────────
# SQLite path. Defaults to a local file in development.
DATABASE_URL="file:./dev.db"

# ── Anthropic Claude (optional, but recommended) ──────────────
# Get a key at https://console.anthropic.com/
# When set, Forge uses Claude as the primary reasoning model.
ANTHROPIC_API_KEY=""

# Optional: override the API base URL (e.g. for a proxy).
# ANTHROPIC_BASE_URL="https://api.anthropic.com"

# ── GitHub (optional) ─────────────────────────────────────────
# Create a token at:
# https://github.com/settings/tokens/new?scopes=repo&description=Forge%20AI%20Software%20Engineer
# Required scope: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=""

# ── Runtime mode (optional) ───────────────────────────────────
# Controls how the agent executes tools:
#   demo  — fully simulated, no network/filesystem (default on Vercel without keys)
#   cloud — Vercel serverless, read-only tools live, mutating tools simulated
#   local — real execution against a local working tree (requires the worker)
FORGE_RUNTIME_MODE="demo"

# ── Vercel detection (set automatically by Vercel) ────────────
# VERCEL=1
